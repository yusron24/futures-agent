# Server
PORT=5000

# CoinGecko API (free public API)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Optional: CoinGecko Pro/Demo API key. Leave empty to use the free public tier.
COINGECKO_API_KEY=

# Optional social data providers (leave empty to skip social scoring - a
# neutral placeholder score is used automatically when no key is set)
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=
SOCIAL_API_KEY=

# Optional on-chain data providers (leave empty to use deterministic dummy
# on-chain data - clearly flagged in the API/UI - instead of live data).
# CryptoQuant exchange flows (BTC/ETH only; https://cryptoquant.com)
CRYPTOQUANT_API_KEY=
# Glassnode (reserved for future use, not yet wired to a live endpoint)
GLASSNODE_API_KEY=
# Whale Alert (>$100k transactions; https://whale-alert.io)
WHALE_ALERT_API_KEY=

# Screening engine
# How many top-movers get "detailed" analysis (RSI/MACD/volume spike) per
# cycle. Kept low to respect the CoinGecko free-tier rate limit (which in
# practice is closer to 5-15 req/min than the docs suggest). Raise this
# only if you have a CoinGecko API key, or you'll mostly see 429 retries.
DETAILED_COINS_LIMIT=30
# Milliseconds to wait between each detailed-coin request within a cycle.
DETAILED_FETCH_DELAY_MS=4000
# Minutes between full screening recalculations (cron job)
SCAN_INTERVAL_MINUTES=5
# Score threshold (0-100) above which a coin is logged as a "signal"
SIGNAL_SCORE_THRESHOLD=75

# Frontend origin allowed to call this API / connect via websocket
CORS_ORIGIN=http://localhost:5173
