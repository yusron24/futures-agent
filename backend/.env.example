# Server
PORT=5000

# Binance Futures API (public market data, no API key needed)
BINANCE_FUTURES_API_URL=https://fapi.binance.com
# Milliseconds between each Binance request (auto-adjusts up on 429/418,
# back down after a run of successes - see utils/binanceClient.js). Binance's
# public market-data rate limit is generous, so this starts fast.
BINANCE_FETCH_DELAY_MS=120

# Optional outbound proxy for Binance requests - helps if your IP gets
# rate-limited or banned (common on shared/mobile/datacenter IPs).
# Format: http://username:password@host:port
# NEVER commit a real value here - keep it in your local .env only (which
# is gitignored), or set it via the Settings page instead (stored in
# SQLite, also not committed). Leave empty to disable.
PROXY_URL=
PROXY_ENABLED=false

# Optional social data providers (leave empty to skip social scoring - a
# neutral placeholder score is used automatically when no key is set)
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=
SOCIAL_API_KEY=

# Optional on-chain data providers (leave empty to use deterministic dummy
# on-chain data - clearly flagged in the API/UI - instead of live data).
# CryptoQuant exchange flows (BTC/ETH only; https://cryptoquant.com)
CRYPTOQUANT_API_KEY=
# Glassnode (reserved for future use, not yet wired to a live endpoint)
GLASSNODE_API_KEY=
# Whale Alert (>$100k transactions; https://whale-alert.io)
WHALE_ALERT_API_KEY=

# Screening engine
# How many top pairs (by 24h quote volume) make up the screening universe.
# Binance's USDT-M perpetual futures list has roughly 300+ symbols; every
# pair in this universe gets full RSI/MACD/volume-spike analysis each
# cycle (Binance's rate limit easily handles this, unlike the old
# CoinGecko-backed version which had to limit this to ~30).
DETAILED_COINS_LIMIT=150
# Minutes between full screening recalculations (cron job)
SCAN_INTERVAL_MINUTES=5
# Score threshold (0-100) above which a coin is logged as a "signal"
SIGNAL_SCORE_THRESHOLD=75

# Frontend origin allowed to call this API / connect via websocket
CORS_ORIGIN=http://localhost:5173
# Public URL of the frontend, used to build "view detail" links in
# Telegram/Discord notifications.
FRONTEND_URL=http://localhost:5173

# Optional Telegram/Discord alerts, sent when a watchlisted coin crosses
# the score threshold or a new "potensi pergerakan besar" signal fires.
# See README.md for how to obtain these. Can also be set/toggled from the
# Settings page instead of here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false
