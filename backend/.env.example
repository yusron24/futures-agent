# Server
PORT=5000

# CoinGecko API (free public API)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
# Optional: CoinGecko Pro/Demo API key. Leave empty to use the free public tier.
COINGECKO_API_KEY=

# Optional social data providers (leave empty to skip social scoring - a
# neutral placeholder score is used automatically when no key is set)
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=
SOCIAL_API_KEY=

# Screening engine
# How many top-movers get "detailed" analysis (RSI/MACD/volume spike) per
# cycle. Kept low to respect the CoinGecko free-tier rate limit.
DETAILED_COINS_LIMIT=60
# Minutes between full screening recalculations (cron job)
SCAN_INTERVAL_MINUTES=5
# Score threshold (0-100) above which a coin is logged as a "signal"
SIGNAL_SCORE_THRESHOLD=75

# Frontend origin allowed to call this API / connect via websocket
CORS_ORIGIN=http://localhost:5173
